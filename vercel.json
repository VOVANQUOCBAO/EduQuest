{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "**/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/img/(.*)", "dest": "/img/$1" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
